# Ollama Configuration
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_THREADS=4
OLLAMA_MAX_CTX=2048
OLLAMA_DISABLE_WHITELIST=0

# Service Ports
OLLAMA_PORT=127.0.0.1:11434
WEBUI_PORT=8282
NGINX_PORT=80

# Resource Limits
OLLAMA_CPUS=2.0
OLLAMA_MEMORY=4g
WEBUI_CPUS=1.0
WEBUI_MEMORY=1g

# Open WebUI Configuration
WEBUI_OLLAMA_API_BASE_URL=http://host.docker.internal:11434/api

# Nginx Configuration
NGINX_WORKER_PROCESSES=1
NGINX_WORKER_CONNECTIONS=1024
